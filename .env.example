# Neon Postgres connection string (psycopg-style is fine, the app normalizes it for asyncpg)
DATABASE_URL=

# Hardcoded admin login (no signup flow for admin). Upserted on every boot.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=12
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# MUST be true in production.
# uvicorn/gunicorn sits behind Nginx/Caddy, so without this get_client_ip() returns the
# PROXY's IP for every user and all WiFi matching silently breaks (everyone looks like
# they're on the same network). Verify with: curl https://<api>/api/debug/my-ip  from your
# phone -- it must return YOUR public IP, not 127.0.0.1.
# Keep it false for local dev (no proxy).
# ---------------------------------------------------------------------------
TRUST_PROXY=false

# Enables /api/debug/* (my-ip, set-time, run-nightly, run-idle-checkout) and allows
# local/private IPs to be registered as office IPs. NEVER true in production.
DEV_MODE=true

# Timezone for scheduling the daily jobs. Per-office timezones live on the `offices` row.
# DISPLAY_TZ is accepted as an alias.
DISPLAY_TIMEZONE=Asia/Karachi

# --- Presence / GPS ---------------------------------------------------------
# Browser coords.accuracy worse than this (metres) is rejected: "move near a window".
MAX_GPS_ACCURACY_M=100
# Fallback radius for a NEW office; each office stores its own radius_meters.
DEFAULT_GPS_RADIUS_M=80
# On a GPS day, how often the client re-sends coords so last_seen keeps advancing.
GPS_REVERIFY_MINUTES=15

# --- Check-out --------------------------------------------------------------
# The 15-min job closes anyone whose last_seen is older than this.
# check_out = min(last_seen, shift_end). Check-out is never a button.
CHECKOUT_IDLE_MINUTES=60

# --- Scheduler --------------------------------------------------------------
# ONLY the dedicated scheduler process may set this to true (see
# deploy/attendance-scheduler.service). API workers must leave it false, or the
# idle-checkout and nightly jobs run once per worker.
RUN_SCHEDULER=false

# Device binding: registering a 3rd device auto-revokes the oldest.
MAX_DEVICES_PER_USER=2

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

