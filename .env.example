# Neon Postgres connection string (psycopg-style is fine, the app normalizes it for asyncpg)
DATABASE_URL=

# Hardcoded admin login (no signup flow for admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=12
REFRESH_TOKEN_EXPIRE_DAYS=30

# Set to true only if FastAPI sits behind a reverse proxy that sets X-Forwarded-For
TRUST_PROXY=false

# Enables /api/debug/* endpoints and allows local/private IPs as office networks
DEV_MODE=true

# Timezone used for displaying dates/times and for scheduling the daily jobs
DISPLAY_TIMEZONE=Asia/Karachi

# Random presence checks
RANDOM_CHECK_WINDOW_START=10:00
RANDOM_CHECK_WINDOW_END=17:00
RANDOM_CHECKS_PER_DAY=4
CHECK_RESPONSE_WINDOW_MINUTES=15

# Device binding
MAX_DEVICES_PER_USER=2

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
